# Build output
build/
*.o
*.s
*.d

# Editor / OS
.cache/
compile_commands.json
*.swp
.DS_Store

# Python bits used by the upstream test mirrors
__pycache__/
*.pyc
.venv/

# Files generated by the instrumented tests
tsan.supp
tests/syzygy
tests/bench_tmp.epd

# Neural network files (mcfish does not use one today; keep the pattern so a
# stray download from an upstream script is never committed)
**/*.nnue

# Throwaway checkouts made for isolated agent runs; never part of the tree.
.claude/worktrees/
# Syzygy tables fetched by `./build.sh tb-fetch`. A runtime input like the net,
# never a repository artefact: the 3-man set alone is 10 binary files, and the
# `tb` gate reports plainly when they are absent rather than passing quietly.
net/
*.rtbw
*.rtbz
